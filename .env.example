POSTGRES_PASSWORD=hindsight

JWT_SECRET=
ENCRYPTION_KEY=

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Email Service Configuration
# Email service provider: smtp or sendgrid
HINDSIGHT_MANAGER_EMAIL_SERVICE=smtp

# SMTP Configuration (for email_service=smtp)
HINDSIGHT_MANAGER_SMTP_HOST=smtp.example.com
HINDSIGHT_MANAGER_SMTP_PORT=587
HINDSIGHT_MANAGER_SMTP_USERNAME=noreply@example.com
HINDSIGHT_MANAGER_SMTP_PASSWORD=your_smtp_password
HINDSIGHT_MANAGER_SMTP_FROM_EMAIL=noreply@example.com
HINDSIGHT_MANAGER_SMTP_USE_TLS=true

# SendGrid Configuration (for email_service=sendgrid)
HINDSIGHT_MANAGER_SENDGRID_API_KEY=your_sendgrid_api_key
HINDSIGHT_MANAGER_SENDGRID_FROM_EMAIL=noreply@example.com

# Auto-registration token (must match xinyi-platform's)
HINDSIGHT_MANAGER_REGISTRATION_TOKEN=
