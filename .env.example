# =============================================================================
# Hindsight Manager — 环境变量配置说明
# =============================================================================
# 所有变量前缀为 HINDSIGHT_MANAGER_，读取 .env 文件（见 config.py）

# ── 数据库 ──────────────────────────────────────────────────────────────────
# PostgreSQL 连接串（asyncpg 协议）。变更会导致所有数据查询失败。
HINDSIGHT_MANAGER_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hindsight_dev

# Manager 数据库 schema 名称。默认为 manager。
# 多个服务共用同一数据库时，用于隔离各自的数据表。
# HINDSIGHT_MANAGER_MANAGER_SCHEMA=manager

# ── 认证 ────────────────────────────────────────────────────────────────────
# JWT 签名密钥。变更会使所有已签发的 session、access token 失效，用户需重新登录。
# 首次部署时生成：python -c "import secrets; print(secrets.token_hex(32))"
HINDSIGHT_MANAGER_JWT_SECRET=<必填, 64字符hex>

# SM4 加密密钥（16 字节 = 32 hex 字符）。
# 用于加密 system API key。变更后无法解密已有密钥，需重新生成 system API key。
# 生成：python -c "import secrets; print(secrets.token_hex(16))"
# ⚠️ 警告：一旦变更，所有已加密的 API key 将永久无法解密。
HINDSIGHT_MANAGER_ENCRYPTION_KEY=<必填, 32字符hex>

# 认证提供方：local（用户名密码）或 cas（CAS SSO）
# HINDSIGHT_MANAGER_AUTH_PROVIDER=local
# HINDSIGHT_MANAGER_CAS_SERVER_URL=
# HINDSIGHT_MANAGER_CAS_SERVICE_URL=

# 初始管理员密码。首次启动时自动创建 admin 用户。
# 生产环境建议首次登录后禁用或删除。
# HINDSIGHT_MANAGER_ADMIN_PASSWORD=<可选>

# Session cookie 是否启用 Secure 属性。开发环境（http）设为 false。
# 生产环境（https）必须设为 true，否则 cookie 被浏览器拒绝。
HINDSIGHT_MANAGER_SESSION_SECURE=false

# ── 数据面（Hindsight API） ────────────────────────────────────────────────
# 数据面 API 地址。Manager 通过此地址代理请求到 Hindsight API。
# 变更会影响所有经由 /api/proxy/ 的请求。
HINDSIGHT_MANAGER_DATAPLANE_URL=http://localhost:8888

# ── 控制面（Hindsight Control Plane） ──────────────────────────────────────
# 控制面的域名基础。控制面 URL 格式：{tenant_slug}.{cp_base_domain}:{cp_port}
# 例如 slug="tenant_abc" 时 URL = http://tenant_abc.cp.local.mem99.cn:9996
# 变更会影响 OTP 重定向目标 URL，必须与控制面服务的 DNS / 端口一致。
HINDSIGHT_MANAGER_CP_BASE_DOMAIN=cp.local.mem99.cn
HINDSIGHT_MANAGER_CP_PORT=9996
HINDSIGHT_MANAGER_CP_SCHEME=http

# ── xinyi-platform 集成（OAuth2 SSO） ──────────────────────────────────────
# xinyi 平台的地址。变更会影响登录重定向、平台用户管理等跳转链接。
HINDSIGHT_MANAGER_PLATFORM_URL=http://localhost:8000/xinyi

# OAuth2 客户端标识。必须与 xinyi 平台注册的 client_id 一致。
HINDSIGHT_MANAGER_OAUTH_CLIENT_ID=hm-prod

# OAuth2 redirect URI。可选字段，省略时由 Manager 根据 base_url 自动拼接。
# HINDSIGHT_MANAGER_OAUTH_REDIRECT_URI=/auth/callback

# Manager 自身的基础 URL（用于向 xinyi 平台注册）。
# 变更会影响 OAuth 回调 URL 的拼接。
HINDSIGHT_MANAGER_BASE_URL=http://localhost:8001

# 平台注册 token。必须与 xinyi 平台的 HINDSIGHT_PLATFORM_REGISTRATION_TOKENS 匹配。
# 否则 Manager 无法自动注册到平台，产品切换器等功能不可用。
HINDSIGHT_MANAGER_REGISTRATION_TOKEN=<可选, 与平台端保持一致>

# ── Session & Token 有效期 ─────────────────────────────────────────────────
# Access token 有效期（秒）。默认 900（15 分钟）。过期后需用 refresh token 续期。
# HINDSIGHT_MANAGER_ACCESS_TOKEN_TTL_SECONDS=900
# Refresh token 有效期（天）。默认 7。
# HINDSIGHT_MANAGER_REFRESH_TOKEN_TTL_DAYS=7

# ── 服务监听 ────────────────────────────────────────────────────────────────
# HINDSIGHT_MANAGER_HOST=0.0.0.0
# HINDSIGHT_MANAGER_PORT=8001

# ── 品牌与文档 ─────────────────────────────────────────────────────────────
# HINDSIGHT_MANAGER_BRAND_NAME=Hindsight
# HINDSIGHT_MANAGER_DOCS_URL=https://hindsight.vectorize.io/best-practices

# ── 邮件服务（可选） ──────────────────────────────────────────────────────
# HINDSIGHT_MANAGER_EMAIL_SERVICE=smtp
# HINDSIGHT_MANAGER_SMTP_HOST=smtp.example.com
# HINDSIGHT_MANAGER_SMTP_PORT=587
# HINDSIGHT_MANAGER_SMTP_USERNAME=noreply@example.com
# HINDSIGHT_MANAGER_SMTP_PASSWORD=your_smtp_password
# HINDSIGHT_MANAGER_SMTP_FROM_EMAIL=noreply@example.com
# HINDSIGHT_MANAGER_SMTP_USE_TLS=true
# HINDSIGHT_MANAGER_SENDGRID_API_KEY=your_sendgrid_api_key
# HINDSIGHT_MANAGER_SENDGRID_FROM_EMAIL=noreply@example.com
